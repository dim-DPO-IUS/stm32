/**
  * @brief  Переход в режим SLEEP
  */
void Enter_Sleep(void)
{
    // Гасим светодиод
    HAL_GPIO_WritePin(LD2_GPIO_Port, LD2_Pin, GPIO_PIN_RESET);

    // Вход в сон: ждём прерывания (WFI)
    // Только кнопка (EXTI) сможет разбудить МК
    HAL_PWR_EnterSLEEPMode(PWR_MAINREGULATOR_ON, PWR_SLEEPENTRY_WFI);
}

/**
  * @brief  Callback прерывания кнопки (PC13)
  */
void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin)
{
    if(GPIO_Pin == GPIO_PIN_13)
    {
        button_pressed = 1;  // Ставим флаг пробуждения
    }
}

/* USER CODE END 0 */

/**
  * @brief  The application entry point.
  */
int main(void)
{
  /* MCU Configuration--------------------------------------------------------*/
  HAL_Init();
  SystemClock_Config();
  MX_GPIO_Init();
  MX_USART2_UART_Init();

  /* USER CODE BEGIN 2 */
  // Индикация старта (3 мигания)
  for(int i = 0; i < 3; i++) {
      HAL_GPIO_TogglePin(LD2_GPIO_Port, LD2_Pin);
      HAL_Delay(200);
  }
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    // === 1. РАБОТА: 5 секунд мигаем ===
    button_pressed = 0;  // Сброс флага
    uint32_t start = HAL_GetTick();

    while(HAL_GetTick() - start < 5000)  // 5 секунд
    {
        HAL_GPIO_TogglePin(LD2_GPIO_Port, LD2_Pin);
        HAL_Delay(500);

        // Если нажали кнопку — сразу выходим из цикла
        if(button_pressed) break;
    }

    // === 2. СОН: если не прервали кнопкой ===
    if(!button_pressed)
    {
        Enter_Sleep();  // МК засыпает здесь
    }

    // === 3. ПРОБУЖДЕНИЕ: индикация ===
    // Код сюда попадает только после нажатия кнопки
    for(int i = 0; i < 3; i++) {
        HAL_GPIO_TogglePin(LD2_GPIO_Port, LD2_Pin);
        HAL_Delay(200);
    }
    /* USER CODE END WHILE */
  }
  /* USER CODE END 3 */
}

