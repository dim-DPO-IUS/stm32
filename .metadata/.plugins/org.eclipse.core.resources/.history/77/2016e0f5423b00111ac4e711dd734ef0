#include "crc_utils.h"

uint8_t crc8_compute(const uint8_t* data, size_t len)
{
    uint16_t sum = 0;
    for (size_t i = 0; i < len; i++)
    {
        sum += data[i];
    }
    return (uint8_t)((0x100 - (sum & 0xFF)) & 0xFF);
}

bool crc8_verify(const uint8_t* data, size_t len, uint8_t expected_crc)
{
    return crc8_compute(data, len) == expected_crc;
}

uint8_t crc_hex_char_to_byte(char c)
{
    if (c >= '0' && c <= '9') return (uint8_t)(c - '0');
    if (c >= 'A' && c <= 'F') return (uint8_t)(c - 'A' + 10);
    if (c >= 'a' && c <= 'f') return (uint8_t)(c - 'a' + 10);
    return 0;
}
