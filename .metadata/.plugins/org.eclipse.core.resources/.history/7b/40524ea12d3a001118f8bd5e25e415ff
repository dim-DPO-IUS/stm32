/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_USART2_UART_Init();
  MX_USB_DEVICE_Init();
  MX_IWDG_Init();

  /* USER CODE BEGIN 2 */
  Read_Raw_CSR(&g_csr);
  __HAL_RCC_CLEAR_RESET_FLAGS();

  HexProcessing_Init();
  g_line_pos = 0;
  g_cdc_ready = false;
  g_programming_mode = false;

  uint32_t start_time = HAL_GetTick();
  uint32_t last_led_tick = 0;
  uint32_t last_check = 0;
  uint8_t led_step = 0;
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
//    FeedWatchdog();

    uint32_t now = HAL_GetTick();

    // ========================================================================
    // РЕЖИМ ПРОГРАММИРОВАНИЯ (ожидание завершения)
    // ========================================================================
    if (g_programming_mode)
    {
        // В режиме программирования только ждём завершения
        // g_cdc_ready сбросится в CDC_Receive_Handler()
        if (!g_cdc_ready)
        {
            g_programming_mode = false;
            HAL_GPIO_WritePin(LD2_GPIO_Port, LD2_Pin, GPIO_PIN_RESET);
        }
        // Продолжаем цикл, не проверяем таймаут и кнопку
        continue;
    }

    // ========================================================================
    // НОРМАЛЬНЫЙ РЕЖИМ: проверка таймаута 5 секунд
    // ========================================================================
    if ((now - start_time) >= 5000)
    {
        // Время вышло, кнопка не нажата → запуск App
        AppStart();
    }

    // ========================================================================
    // ПАТТЕРН МИГАНИЯ (каждые 100ms)
    // ========================================================================
    if ((now - last_led_tick) >= 100)
    {
        last_led_tick = now;

        if (LED_PATTERN & (1 << (7 - led_step)))
            HAL_GPIO_WritePin(LD2_GPIO_Port, LD2_Pin, GPIO_PIN_SET);
        else
            HAL_GPIO_WritePin(LD2_GPIO_Port, LD2_Pin, GPIO_PIN_RESET);

        led_step = (led_step + 1) % 8;
    }

    // ========================================================================
    // ПРОВЕРКА КНОПКИ (каждые 50ms)
    // ========================================================================
    if ((now - last_check) >= 50)
    {
        last_check = now;

        if (HAL_GPIO_ReadPin(B1_GPIO_Port, B1_Pin) == GPIO_PIN_RESET)
        {
            HAL_Delay(50);  // debounce
            if (HAL_GPIO_ReadPin(B1_GPIO_Port, B1_Pin) == GPIO_PIN_RESET)
            {
                // Кнопка нажата → вход в режим программирования
                HexProcessing_Init();
                g_line_pos = 0;
                g_cdc_ready = true;
                g_programming_mode = true;

                // Индикация входа в режим программирования
                HAL_GPIO_WritePin(LD2_GPIO_Port, LD2_Pin, GPIO_PIN_SET);
            }
        }
    }

    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

