#include "main.h"
#include "mylib.h"

// ============================================================================
//  ПРОТОТИПЫ ФУНКЦИЙ
// ============================================================================
void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_USART2_UART_Init(void);
void Error_Handler(void);

// ============================================================================
//  ПЕРЕМЕННЫЕ
// ============================================================================
UART_HandleTypeDef huart2;

// ============================================================================
//  MAIN
// ============================================================================
int main(void)
{
    HAL_Init();
    SystemClock_Config();
    MX_GPIO_Init();
    MX_USART2_UART_Init();

    // Гасим светодиод
    HAL_GPIO_WritePin(LD2_GPIO_Port, LD2_Pin, GPIO_PIN_RESET);

    while (1)
    {
        // Ждём нажатия кнопки B1
        if (HAL_GPIO_ReadPin(B1_GPIO_Port, B1_Pin) == GPIO_PIN_RESET)
        {
            HAL_Delay(50);  // Антидребезг
            if (HAL_GPIO_ReadPin(B1_GPIO_Port, B1_Pin) == GPIO_PIN_RESET)
            {
                // Зажигаем светодиод
                HAL_GPIO_WritePin(LD2_GPIO_Port, LD2_Pin, GPIO_PIN_SET);

                // Вызываем тестовую запись
                HAL_StatusTypeDef result = Test_Flash_Write();

                // Индикация результата
                if (result == HAL_OK)
                {
                    // Успех: мигаем 3 раза медленно
                    for (int i = 0; i < 3; i++)
                    {
                        HAL_GPIO_TogglePin(LD2_GPIO_Port, LD2_Pin);
                        HAL_Delay(500);
                    }
                }
                else
                {
                    // Ошибка: мигаем 5 раз быстро
                    for (int i = 0; i < 5; i++)
                    {
                        HAL_GPIO_TogglePin(LD2_GPIO_Port, LD2_Pin);
                        HAL_Delay(100);
                    }
                }
                HAL_GPIO_WritePin(LD2_GPIO_Port, LD2_Pin, GPIO_PIN_RESET);

                // Ждём отпускания кнопки
                while (HAL_GPIO_ReadPin(B1_GPIO_Port, B1_Pin) == GPIO_PIN_RESET);
                HAL_Delay(100);
            }
        }
    }
}

