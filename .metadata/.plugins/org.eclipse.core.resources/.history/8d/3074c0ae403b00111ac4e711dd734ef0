#ifndef BOOT_CORE_H
#define BOOT_CORE_H

#include <stdint.h>
#include <stdbool.h>
#include <stddef.h>

#ifdef __cplusplus
extern "C" {
#endif

// ============================================================================
//  КОНФИГУРАЦИЯ (СЕКТОР 4 — РАБОЧАЯ ВЕРСИЯ)
// ============================================================================
#define BOOT_SECTOR_NUM          FLASH_SECTOR_4
#define BOOT_SECTOR_START        0x08010000UL
#define BOOT_SECTOR_END          0x0801FFFFUL
#define BOOT_SECTOR_SIZE         65536U

#define APP_START_ADDRESS        0x0800C000UL

// Целевые адреса для записи данных из HEX-файла (Сектор 4)
static const uint32_t TARGET_ADDRESSES[] = {
    0x08010000,
    0x08010010,
    0x08010020,
    0x08010030,
    0x08010040
};

#define TARGET_ADDR_COUNT        (sizeof(TARGET_ADDRESSES) / sizeof(TARGET_ADDRESSES[0]))
#define MAX_DATA_PER_ADDRESS     16

// ============================================================================
//  КОДЫ ОШИБОК
// ============================================================================
#define ERROR_NONE               0
#define ERROR_USB_INIT           1
#define ERROR_CRC                2
#define ERROR_ADDR_OUT_OF_RANGE  3
#define ERROR_ADDR_NOT_FOUND     4
#define ERROR_FLASH_ERASE        5
#define ERROR_FLASH_WRITE        6
#define ERROR_RX_TIMEOUT         7

// ============================================================================
//  ГЛОБАЛЬНЫЕ ПЕРЕМЕННЫЕ (доступны из main.c)
// ============================================================================
extern uint8_t g_last_error;
extern bool g_hex_processing_done;

// ============================================================================
//  ПУБЛИЧНЫЕ ФУНКЦИИ
// ============================================================================

/**
 * @brief Инициализация ядра загрузчика
 */
void boot_core_init(void);

/**
 * @brief Обработка одной строки HEX-файла
 * @param line Строка, начинающаяся с ':'
 * @return     true, если обработка успешна
 */
bool boot_core_process_line(char* line);

/**
 * @brief Финализация обработки HEX-файла (запись во Flash)
 * @return true, если запись успешна
 */
bool boot_core_finalize(void);

/**
 * @brief Установка кода ошибки
 * @param error_code Код ошибки (ERROR_*)
 */
void boot_core_set_error(uint8_t error_code);

/**
 * @brief Получение последнего кода ошибки
 * @return Код ошибки
 */
uint8_t boot_core_get_error(void);

/**
 * @brief Сброс состояния ядра для нового сеанса
 */
void boot_core_reset(void);

#ifdef __cplusplus
}
#endif

#endif /* BOOT_CORE_H */
