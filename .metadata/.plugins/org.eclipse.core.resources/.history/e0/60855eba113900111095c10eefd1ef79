// ============================================================================
//  ОБРАБОТЧИК ПРИНЯТЫХ ПО USB CDC ДАННЫХ
// ============================================================================
void CDC_Receive_Handler(uint8_t* Buf, uint32_t Len)
{
    if (!g_cdc_ready) return;

    for (uint32_t i = 0; i < Len; i++)
    {
        char c = (char)Buf[i];

        if (c == '\n')
        {
            if (g_line_pos > 0)
            {
                g_line_buffer[g_line_pos] = '\0';

                if (!HexProcessing_ProcessLine(g_line_buffer))
                {
                    g_cdc_ready = false;
                    return;
                }
                g_line_pos = 0;
            }
        }
        else if (c == '\r')
        {
            continue;
        }
        else
        {
            if (g_line_pos < HEX_LINE_BUFFER_SIZE - 1)
            {
                g_line_buffer[g_line_pos++] = c;
            }
            else
            {
                SetError(ERROR_CRC);
                g_cdc_ready = false;
                return;
            }
        }
    }

    if (g_hex_processing_done)
    {
        g_cdc_ready = false;

        if (HexProcessing_Finalize())
        {
            HAL_GPIO_WritePin(LD2_GPIO_Port, LD2_Pin, GPIO_PIN_SET);
            HAL_Delay(2000);
            HAL_GPIO_WritePin(LD2_GPIO_Port, LD2_Pin, GPIO_PIN_RESET);
        }
    }
}

