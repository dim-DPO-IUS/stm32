int main(void)
{
    /* USER CODE BEGIN 1 */

    /* USER CODE END 1 */

    HAL_Init();

    /* USER CODE BEGIN Init */

    /* USER CODE END Init */

    SystemClock_Config();

    /* USER CODE BEGIN SysInit */

    /* USER CODE END SysInit */

    MX_GPIO_Init();
    MX_USART2_UART_Init();
    MX_IWDG_Init();
    MX_USB_DEVICE_Init();

    /* USER CODE BEGIN 2 */
    Read_Raw_CSR(&g_csr);
    __HAL_RCC_CLEAR_RESET_FLAGS();

    HexProcessing_Init();
    g_line_pos = 0;
    g_cdc_ready = false;
    g_button_processed = false;
    /* USER CODE END 2 */

    /* Infinite loop */
    while (1)
    {
        FeedWatchdog();

        // Проверка кнопки
        if (HAL_GPIO_ReadPin(B1_GPIO_Port, B1_Pin) == GPIO_PIN_RESET)
        {
            HAL_Delay(50);
            if (HAL_GPIO_ReadPin(B1_GPIO_Port, B1_Pin) == GPIO_PIN_RESET)
            {
                HexProcessing_Init();
                g_line_pos = 0;
                g_cdc_ready = true;
                g_button_processed = true;

                HAL_GPIO_WritePin(LD2_GPIO_Port, LD2_Pin, GPIO_PIN_SET);
                HAL_Delay(1000);
                HAL_GPIO_WritePin(LD2_GPIO_Port, LD2_Pin, GPIO_PIN_RESET);

                while (g_cdc_ready)
                {
                    FeedWatchdog();
                    HAL_Delay(10);
                }

                HAL_Delay(500);
                g_button_processed = false;
            }
        }

        HAL_Delay(10);
    }
}

