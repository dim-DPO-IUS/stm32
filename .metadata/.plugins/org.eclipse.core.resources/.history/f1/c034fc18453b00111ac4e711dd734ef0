#ifndef HEX_PARSER_H
#define HEX_PARSER_H

#include <stdint.h>
#include <stdbool.h>
#include <stddef.h>

#ifdef __cplusplus
extern "C" {
#endif

typedef enum {
    HEX_RECORD_DATA = 0x00,
    HEX_RECORD_EOF  = 0x01,
    HEX_RECORD_ESA  = 0x02,
    HEX_RECORD_SSA  = 0x03,
    HEX_RECORD_ELA  = 0x04,
    HEX_RECORD_SLA  = 0x05
} HexRecordType;

typedef struct {
    HexRecordType type;
    uint32_t      address;
    uint8_t       data[256];
    uint8_t       data_len;
    bool          crc_valid;
} HexRecord;

void hex_parser_init(void);
bool hex_parser_parse_line(const char* line, HexRecord* record);
uint32_t hex_parser_get_ela(void);
uint16_t hex_parser_get_esa(void);
bool hex_parser_using_linear(void);

#ifdef __cplusplus
}
#endif

#endif /* HEX_PARSER_H */
